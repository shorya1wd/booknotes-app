<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <%- include('partials/header.ejs'); -%>

<div class="book-detail-container">
    <h1 style="text-align: center;">Find a Book</h1>

    <form action="/search" method="POST" class="search-form">
        <input type="text" name="query" placeholder="Enter book name (e.g. Harry Potter)" required>
        <button type="submit" class="btn-save">Search</button>
    </form>

    <hr style="border: 0; height: 1px; background: #444; margin: 30px 0;">

    <% if (locals.books) { %>
        <h2 style="text-align: center; margin-bottom: 20px;">Results:</h2>
        
        <div class="book-grid">
            <% books.forEach(book => { %>
                <div class="book-card">
                    <% const coverUrl = book.cover_i ? `https://covers.openlibrary.org/b/id/${book.cover_i}-M.jpg` : 'https://via.placeholder.com/150'; %>
                    <img src="<%= coverUrl %>" alt="cover" class="book-cover">
                    
                    <h3 class="title"><%= book.title %></h3>
                    <p class="author">by <%= book.author_name ? book.author_name[0] : 'Unknown' %></p>
                    
                    <form action="/new" method="POST" style="width: 100%;">
                        <input type="hidden" name="title" value="<%= book.title %>">
                        <input type="hidden" name="author" value="<%= book.author_name ? book.author_name[0] : 'Unknown' %>">
                        <input type="hidden" name="cover_id" value="<%= book.cover_i %>">
                        <button type="submit" class="btn-edit" style="width: 100%;">Select This Book</button>
                    </form>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
</body>
</html>